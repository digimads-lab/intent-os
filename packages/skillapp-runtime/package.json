  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "electron": "^33.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
